<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AUDITUM CERT – Scientific & Technical Auditing Excellence</title>
  <style>
    :root {
      --white: #ffffff;
      --black-soft: #1a1a1a;
      --grey-dark: #4a4a4a;
      --grey-mid: #6e6e6e;
      --green-main: #3cb371;
      --bg-alt: #f7f7f7;
      --border-light: #e0e0e0;
      --radius: 6px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
        sans-serif;
      color: var(--grey-dark);
      background-color: var(--white);
      line-height: 1.6;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .container {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 16px;
    }

    /* HEADER */

    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background-color: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border-light);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo-mark {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background-color: var(--green-main);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
    }

    .logo-text {
      font-weight: 700;
      letter-spacing: 0.08em;
      font-size: 14px;
      text-transform: uppercase;
      color: var(--black-soft);
    }

    .main-nav {
      display: flex;
      align-items: center;
      gap: 18px;
      font-size: 14px;
      flex-wrap: wrap;
    }

    .main-nav a {
      color: var(--grey-dark);
    }

    .main-nav a:hover {
      color: var(--green-main);
    }

    .btn-nav {
      padding: 6px 14px;
      border-radius: 999px;
      border: 1px solid var(--green-main);
      color: var(--green-main);
    }

    /* LANGUAGE SWITCH */

    .lang-switch {
      display: flex;
      gap: 6px;
    }

    .lang-btn {
      border-radius: 999px;
      border: 1px solid var(--border-light);
      background-color: var(--white);
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
      color: var(--grey-mid);
    }

    .lang-btn.active {
      border-color: var(--green-main);
      color: var(--green-main);
    }

    /* HERO */

    .hero {
      padding: 80px 0 60px;
    }

    .hero-inner {
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .hero-text h1 {
      font-size: 40px;
      margin: 0 0 8px;
      color: var(--black-soft);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-text h2 {
      font-size: 20px;
      margin: 0 0 16px;
      color: var(--grey-mid);
    }

    .hero-line {
      width: 80px;
      height: 3px;
      background-color: var(--green-main);
      margin-bottom: 16px;
    }

    .hero-text p {
      max-width: 520px;
      margin-bottom: 24px;
    }

    .btn-primary {
      display: inline-block;
      padding: 10px 22px;
      border-radius: 999px;
      background-color: var(--green-main);
      color: var(--white);
      font-weight: 600;
      border: none;
      cursor: pointer;
      font-size: 14px;
    }

    .btn-primary:hover {
      background-color: #34a066;
    }

    /* SECTIONS */

    .section {
      padding: 60px 0;
    }

    .section-alt {
      background-color: var(--bg-alt);
    }

    .section h2 {
      font-size: 24px;
      margin-bottom: 24px;
      color: var(--black-soft);
    }

    /* CARDS GRID */

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 18px;
    }

    .card {
      border-radius: var(--radius);
      border: 1px solid var(--border-light);
      padding: 18px;
      background-color: var(--white);
    }

    .card h3 {
      margin-top: 0;
      margin-bottom: 8px;
      font-size: 16px;
      color: var(--black-soft);
    }

    /* TWO COLUMNS */

    .two-cols {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 32px;
    }

    /* SERVICES */

    .service-block {
      border-top: 1px solid var(--border-light);
      padding: 20px 0;
    }

    .service-block h3 {
      margin: 0 0 8px;
      color: var(--black-soft);
    }

    .service-block p {
      margin: 0 0 8px;
    }

    /* INDUSTRIES */

    .industries-list {
      list-style: none;
      padding: 0;
      margin: 8px 0 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 6px 18px;
    }

    .industries-list li::before {
      content: "• ";
      color: var(--green-main);
    }

    /* CONTACT FORM */

    .contact-form {
      max-width: 720px;
      margin-top: 16px;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      margin-bottom: 14px;
    }

    .form-group label {
      font-size: 13px;
      margin-bottom: 4px;
      color: var(--grey-mid);
    }

    .form-group input,
    .form-group textarea {
      border-radius: var(--radius);
      border: 1px solid var(--border-light);
      padding: 8px 10px;
      font-size: 14px;
      font-family: inherit;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: 1px solid var(--green-main);
    }

    /* FOOTER */

    .site-footer {
      border-top: 1px solid var(--border-light);
      padding: 16px 0;
      background-color: var(--white);
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
      color: var(--grey-mid);
    }

    /* RESPONSIVE */

    @media (max-width: 900px) {
      .header-inner {
        flex-wrap: wrap;
        align-items: flex-start;
      }

      .main-nav {
        order: 3;
      }

      .lang-switch {
        order: 2;
      }
    }

    @media (max-width: 768px) {
      .hero {
        padding-top: 60px;
      }

      .hero-text h1 {
        font-size: 32px;
      }
    }
  </style>
